{
  "name": "chorograph-app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Chorograph app — Vite + TypeScript + WebGL2; tests via node:test (zero native deps).",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/checksize.mjs",
    "preview": "vite preview",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=23.6"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-singlefile": "^2.3.3"
  },
  "dependencies": {
    "@preact/signals": "^2.9.2",
    "preact": "^10.29.4"
  }
}
